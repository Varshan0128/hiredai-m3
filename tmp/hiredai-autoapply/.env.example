# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://hiredai:hiredai@localhost:5432/hiredai_db"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"

# ── API (NestJS) ──────────────────────────────────────────────────────────────
API_PORT=4000
API_URL="http://localhost:4000"
CORS_ORIGIN="http://localhost:3000"

# ── Web (Next.js) ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-this-in-production"

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_PROVIDER="local"
LOCAL_STORAGE_PATH="./uploads"
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_ENDPOINT=""

# ── Adzuna ────────────────────────────────────────────────────────────────────
ADZUNA_APP_ID="your-adzuna-app-id"
ADZUNA_APP_KEY="your-adzuna-app-key"
ADZUNA_BASE_URL="https://api.adzuna.com/v1/api"
ADZUNA_COUNTRY="gb"

# ── Jooble ────────────────────────────────────────────────────────────────────
JOOBLE_API_KEY="your-jooble-api-key"
JOOBLE_BASE_URL="https://jooble.org/api"

# ── Worker ────────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=5
INGESTION_INTERVAL_MINUTES=60

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV="development"
LOG_LEVEL="debug"
